# ============================================================================
# JomChats · Aurum pilot — environment variables (BUILD_PLAN §13)
# Copy to .env.local for local dev. Set the real values in Vercel env (never commit).
# ============================================================================

# ---- Supabase (the vault) --------------------------------------------------
SUPABASE_URL=https://nepstvfetjpbjuhfvvpi.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-only. NEVER exposed to the browser.

# ---- Tenant ----------------------------------------------------------------
TENANT_ID=11111111-1111-1111-1111-111111111111
# NOTE: "TZ" is a reserved env var name on Vercel — use APP_TZ instead.
# Code must format dates explicitly in this zone (Intl timeZone), not rely on process.env.TZ.
APP_TZ=Asia/Kuala_Lumpur

# ---- Anthropic (models via env — never hardcode model IDs) -----------------
ANTHROPIC_API_KEY=
ANSWER_MODEL=                          # current Sonnet tier
FAST_MODEL=                            # current Haiku tier (routing/verify/eval)

# ---- Embeddings ------------------------------------------------------------
VOYAGE_API_KEY=

# ---- Meta / WhatsApp Cloud API (§14) ---------------------------------------
META_APP_SECRET=
META_VERIFY_TOKEN=                     # high-entropy string you choose
META_WA_TOKEN=                         # permanent system-user token
META_PHONE_NUMBER_ID=
META_WABA_ID=

# ---- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=
ALERT_EMAIL=jomchats.ai@gmail.com

# ---- Simulator / test harness ----------------------------------------------
SIMULATOR_SECRET=
